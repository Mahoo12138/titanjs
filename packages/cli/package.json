{
  "name": "@neo-hexo/cli",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI entry point for Neo-Hexo — loads neo-hexo.yaml, resolves plugins, dispatches commands.",
  "bin": {
    "neo-hexo": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/"],
  "dependencies": {
    "citty": "^0.1.6",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "@neo-hexo/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
