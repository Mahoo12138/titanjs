{
  "name": "titan-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Titan: A modern static site generator, reimagined.",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' --filter='./plugins/*' --filter='./themes/*' run build",
    "dev": "pnpm -r --filter='./packages/*' --filter='./plugins/*' --filter='./themes/*' run --parallel dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "keywords": [
    "website",
    "blog",
    "ssg",
    "framework",
    "titan"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
